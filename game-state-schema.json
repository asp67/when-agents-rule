{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "When Agents Rule — per-turn game state",
  "description": "The JSON object handed to every model each turn (built by buildGameStateJSON in js/openai-ai.js). Everything is fog-limited: the model only sees what its own units/buildings have discovered. Coordinates are world units on a square map centred on (0,0). In multi-turn history mode, PAST turns are replayed as compact 'pastTurnRecap' objects (see $defs.pastTurnRecap) — the CURRENT full state is always the last message.",
  "type": "object",
  "required": [
    "player",
    "epoch",
    "resources",
    "bonuses",
    "map",
    "resourcesOnMap",
    "friendlyBuildings",
    "buildings",
    "enemyBuildings",
    "friendlyUnits",
    "workers",
    "enemyUnits",
    "research",
    "unlockedContent",
    "trainableUnits",
    "buildableStructures",
    "pendingBuildings",
    "threats",
    "gameStats"
  ],
  "properties": {
    "player": {
      "type": "object",
      "description": "Who you are.",
      "required": [
        "id",
        "civilization",
        "civilizationName",
        "isHuman"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "civilization": {
          "type": "string",
          "enum": [
            "egyptian",
            "greek",
            "persian",
            "yamato"
          ]
        },
        "civilizationName": {
          "type": "string"
        },
        "isHuman": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "epoch": {
      "type": "object",
      "description": "Age progression. Costs come from the shared AGE_COSTS table — identical for every player type.",
      "required": [
        "currentEpoch",
        "nextEpoch",
        "nextEpochCost",
        "upgradeInProgress"
      ],
      "properties": {
        "currentEpoch": {
          "$ref": "#/$defs/age"
        },
        "nextEpoch": {
          "oneOf": [
            {
              "$ref": "#/$defs/age"
            },
            {
              "type": "null"
            }
          ],
          "description": "null at the final age (iron)."
        },
        "nextEpochCost": {
          "oneOf": [
            {
              "$ref": "#/$defs/cost"
            },
            {
              "type": "null"
            }
          ]
        },
        "upgradeInProgress": {
          "oneOf": [
            {
              "type": "object",
              "required": [
                "targetEpoch",
                "progressPercent",
                "secondsRemaining"
              ],
              "properties": {
                "targetEpoch": {
                  "$ref": "#/$defs/age"
                },
                "progressPercent": {
                  "type": "integer"
                },
                "secondsRemaining": {
                  "type": "integer"
                }
              }
            },
            {
              "type": "null"
            }
          ],
          "description": "null when no age-up is running. Do NOT re-issue upgrade_age while non-null."
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "Your stockpile and population.",
      "required": [
        "food",
        "wood",
        "stone",
        "gold",
        "population",
        "maxPopulation",
        "populationFree",
        "populationHardCap"
      ],
      "properties": {
        "food": {
          "type": "integer"
        },
        "wood": {
          "type": "integer"
        },
        "stone": {
          "type": "integer"
        },
        "gold": {
          "type": "integer"
        },
        "population": {
          "type": "integer"
        },
        "maxPopulation": {
          "type": "integer",
          "description": "Raised by houses, up to populationHardCap."
        },
        "populationFree": {
          "type": "integer"
        },
        "populationHardCap": {
          "type": "integer",
          "description": "Hard ceiling (100); houses cannot raise maxPopulation past it."
        }
      }
    },
    "recentEvents": {
      "type": "array",
      "description": "Your battle report: up to 8 recent one-line events (losses, kills, raids), each prefixed with its age, e.g. \"12s ago: LOSS: your house at (140, -80) — destroyed by egyptian\".",
      "items": {
        "type": "string"
      }
    },
    "bonuses": {
      "type": "object",
      "description": "Only NON-DEFAULT multipliers appear (empty object = no active bonuses).",
      "properties": {
        "harvest": {
          "type": "number"
        },
        "attack": {
          "type": "number"
        },
        "health": {
          "type": "number"
        },
        "mining": {
          "type": "number"
        },
        "techCostMult": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "map": {
      "type": "object",
      "description": "World geometry. The map is a square centred on (0,0); enemies can be anywhere inside bounds.",
      "required": [
        "size",
        "bounds",
        "yourSpawnArea"
      ],
      "properties": {
        "size": {
          "type": "number"
        },
        "bounds": {
          "type": "object",
          "required": [
            "minX",
            "maxX",
            "minZ",
            "maxZ"
          ],
          "properties": {
            "minX": {
              "type": "number"
            },
            "maxX": {
              "type": "number"
            },
            "minZ": {
              "type": "number"
            },
            "maxZ": {
              "type": "number"
            }
          }
        },
        "yourSpawnArea": {
          "oneOf": [
            {
              "type": "object",
              "required": [
                "x",
                "z"
              ],
              "properties": {
                "x": {
                  "type": "number"
                },
                "z": {
                  "type": "number"
                }
              }
            },
            {
              "type": "null"
            }
          ],
          "description": "Centre of your buildings (your base)."
        },
        "nodesLeftOnMap": {
          "type": "object",
          "description": "How many resource nodes of each type are STILL on the map right now, across the whole world (e.g. {\"food\":312,\"wood\":690,\"stone\":37,\"gold\":18}). Compare with resourcesOnMap — what YOU have discovered — to judge whether more scouting is worth it, and watch it fall to see the world running dry: a wood figure sliding toward zero is the signal to stop prospecting and commit to farms. Live rather than a starting snapshot, because a fixed figure goes stale and would have you hunting nodes that no longer exist. It is a total only: no positions, no indication of which nodes went or who took them."
        },
        "yourBaseTiles": {
          "type": "object",
          "description": "Which map tiles you occupy, keyed by the same A1-G7 label as exploration, with the number of your buildings in each (e.g. {\"D1\": 7, \"G7\": 1}). Covers a second base or one rebuilt elsewhere after the first fell; empty when you have no buildings left. Deliberately not a single averaged tile: a player holding D1 and G7 has a centroid in E4, where it owns nothing.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          }
        },
        "exploration": {
          "type": "object",
          "description": "Percent (0-100) of each map tile you have ever seen, keyed by tile label: column letter A-G running west to east, then row number 1-7 running north to south (\"C5\" = third column, fifth row). Pass one of these labels as explore's \"tile\". map.yourBaseTile tells you which one you start in. A tile is ~114 units across and a scout sees ~15, so one pass raises a tile by only a few percent.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    },
    "resourcesOnMap": {
      "type": "array",
      "description": "Only nodes you have DISCOVERED (remembered once seen) and that still hold resources. Nodes deplete permanently; scout for fresh ones.",
      "items": {
        "type": "object",
        "required": [
          "type",
          "x",
          "z",
          "amount",
          "visible"
        ],
        "properties": {
          "type": {
            "$ref": "#/$defs/resourceType"
          },
          "x": {
            "type": "integer"
          },
          "z": {
            "type": "integer"
          },
          "amount": {
            "type": "integer",
            "description": "Remaining amount on the node."
          },
          "visible": {
            "type": "boolean",
            "description": "true = a unit sees it right now; false = remembered from an earlier look."
          }
        }
      }
    },
    "battles": {
      "type": "array",
      "description": "Fighting you could not watch, one entry per ENGAGEMENT (clustered by location), CUMULATIVE since it began — a fight outlasts several turns. Absent entirely when nothing is happening. Only engagements you took part in. Numbers only: 'their 2 heavy_cavalry dealt 1800 to my 3 archers' is the counter lesson, drawing it is your job.",
      "items": {
        "type": "object",
        "required": ["at", "ongoing", "secondsElapsed", "you", "enemy"],
        "properties": {
          "at": { "type": "array", "items": { "type": "integer" }, "description": "[x, z] centre of the fighting." },
          "ongoing": { "type": "boolean", "description": "true while blows are still landing." },
          "secondsElapsed": { "type": "integer" },
          "you": { "$ref": "#/properties/battles/items/definitions/side" },
          "enemy": {
            "type": "array",
            "description": "One entry per rival involved — three-way fights are not merged.",
            "items": { "$ref": "#/properties/battles/items/definitions/side" }
          }
        },
        "definitions": {
          "side": {
            "type": "object",
            "properties": {
              "owner": { "type": "string", "description": "Present on enemy entries only." },
              "involved": {
                "type": "object",
                "description": "Keyed by unit/building type — towers, drafted workers and priests all appear as themselves. Zero fields are omitted, so a priest row is just {n, healed}.",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "n": { "type": "integer", "description": "Distinct units of this type that fought or healed." },
                    "dmgUnits": { "type": "integer", "description": "Damage dealt to UNITS." },
                    "dmgBuildings": { "type": "integer", "description": "Damage dealt to BUILDINGS — never summed with dmgUnits, since infantry raze at 1.5x and ranged at 0.5x." },
                    "healed": { "type": "integer", "description": "HP restored (priests). Replaces damage for support units." }
                  }
                }
              },
              "lost": {
                "type": "object",
                "description": "Units of yours (or theirs) that died here, by type. Absent if none.",
                "additionalProperties": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "friendlyBuildings": {
      "type": "array",
      "description": "Every building you own, with its live activity.",
      "items": {
        "type": "object",
        "required": [
          "type",
          "x",
          "z",
          "healthPct",
          "state",
          "busy",
          "activity",
          "producing"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "x": {
            "type": "integer"
          },
          "z": {
            "type": "integer"
          },
          "healthPct": {
            "type": "integer"
          },
          "state": {
            "type": "string",
            "enum": [
              "under_construction",
              "complete"
            ]
          },
          "busy": {
            "type": "boolean",
            "description": "true while producing, under construction, or hosting research/age-up."
          },
          "activity": {
            "type": "string",
            "description": "researching = hosting a TECH (see research.current); advancing_age = hosting the epoch upgrade (see epoch.upgradeInProgress). They are separate tasks and can run at the same time, in different buildings.",
            "enum": [
              "under_construction",
              "producing",
              "researching",
              "advancing_age",
              "idle"
            ]
          },
          "researchingTech": {
            "type": "string",
            "description": "Tech id this building is researching. Only while activity is researching."
          },
          "researchSecondsRemaining": {
            "type": "integer",
            "description": "Seconds until this building finishes its tech. Only while activity is researching."
          },
          "advancingTo": {
            "type": "string",
            "description": "Epoch this Town Center is advancing to. Only while activity is advancing_age."
          },
          "ageSecondsRemaining": {
            "type": "integer",
            "description": "Seconds until the epoch upgrade completes. Only while activity is advancing_age."
          },
          "producing": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Unit type in production, else null."
          },
          "producingSecondsRemaining": {
            "type": "integer"
          },
          "buildPct": {
            "type": "integer",
            "description": "Only while under construction."
          },
          "buildSecondsRemaining": {
            "type": "integer",
            "description": "Only while under construction."
          },
          "wonder": {
            "type": "boolean",
            "description": "Present (true) on your Wonder."
          },
          "food": {
            "type": "integer",
            "description": "Farms only: food currently stocked in the farm."
          }
        }
      }
    },
    "buildings": {
      "type": "object",
      "description": "Aggregate of friendlyBuildings, for at-a-glance rebalancing.",
      "required": [
        "total",
        "idle",
        "busy",
        "underConstruction",
        "producing",
        "researching",
        "byType"
      ],
      "properties": {
        "total": {
          "type": "integer"
        },
        "idle": {
          "type": "integer"
        },
        "busy": {
          "type": "integer"
        },
        "underConstruction": {
          "type": "integer"
        },
        "producing": {
          "type": "integer"
        },
        "researching": {
          "type": "integer"
        },
        "byType": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        }
      }
    },
    "enemyBuildings": {
      "type": "array",
      "description": "Every enemy building you have EVER discovered (buildings are static, so they are remembered). Wonders ignore fog — always listed. Attack by coordinates or pass the exact `id` as attack_target's params.targetId.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "x",
          "z",
          "owner",
          "healthPct",
          "visible"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable target handle for attack_target(params.targetId)."
          },
          "type": {
            "type": "string"
          },
          "x": {
            "type": "integer"
          },
          "z": {
            "type": "integer"
          },
          "owner": {
            "type": "string"
          },
          "healthPct": {
            "type": "integer"
          },
          "visible": {
            "type": "boolean",
            "description": "true = in sight now; false = remembered last-seen location (still a valid target)."
          },
          "isWonder": {
            "type": "boolean"
          },
          "state": {
            "type": "string",
            "enum": [
              "under_construction",
              "complete"
            ],
            "description": "Wonders only."
          },
          "secondsUntilEnemyWins": {
            "oneOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "Wonders only: time until this wonder WINS for its owner. null while under construction."
          }
        }
      }
    },
    "friendlyUnits": {
      "type": "array",
      "description": "Every unit you own and what it is doing right now.",
      "items": {
        "type": "object",
        "required": [
          "type",
          "x",
          "z",
          "healthPct",
          "action"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "x": {
            "type": "integer"
          },
          "z": {
            "type": "integer"
          },
          "healthPct": {
            "type": "integer"
          },
          "action": {
            "type": "string",
            "enum": [
              "idle",
              "attacking",
              "harvesting",
              "returning",
              "building",
              "farm_work",
              "moving"
            ]
          }
        }
      }
    },
    "workers": {
      "type": "object",
      "description": "Live tally of what your villagers are doing — use it to rebalance the economy at a glance.",
      "required": [
        "total",
        "idle",
        "building",
        "onFarms",
        "scouting",
        "returning",
        "moving",
        "harvestingFood",
        "harvestingWood",
        "harvestingStone",
        "harvestingGold"
      ],
      "properties": {
        "total": {
          "type": "integer"
        },
        "idle": {
          "type": "integer"
        },
        "building": {
          "type": "integer"
        },
        "onFarms": {
          "type": "integer"
        },
        "scouting": {
          "type": "integer"
        },
        "returning": {
          "type": "integer"
        },
        "moving": {
          "type": "integer"
        },
        "harvestingFood": {
          "type": "integer"
        },
        "harvestingWood": {
          "type": "integer"
        },
        "harvestingStone": {
          "type": "integer"
        },
        "harvestingGold": {
          "type": "integer"
        }
      }
    },
    "enemyUnits": {
      "type": "array",
      "description": "Enemy units CURRENTLY in your sight (units move, so old positions are not kept). The `id` is a target handle for attack_target — ids track a moving unit better than stale coordinates.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "x",
          "z",
          "owner"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "x": {
            "type": "integer"
          },
          "z": {
            "type": "integer"
          },
          "owner": {
            "type": "string"
          }
        }
      }
    },
    "research": {
      "type": "object",
      "description": "Tech tree status. Only ONE research at a time; never re-research something in `researched`.",
      "required": [
        "researched",
        "current",
        "available"
      ],
      "properties": {
        "researched": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "current": {
          "oneOf": [
            {
              "type": "object",
              "required": [
                "techId",
                "progressPercent",
                "secondsRemaining"
              ],
              "properties": {
                "techId": {
                  "type": "string"
                },
                "progressPercent": {
                  "type": "integer"
                },
                "secondsRemaining": {
                  "type": "integer"
                }
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "available": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "cost",
              "researchAt",
              "canAfford"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "cost": {
                "$ref": "#/$defs/cost"
              },
              "researchAt": {
                "type": "string",
                "description": "Building type that hosts this research (e.g. town_center, market)."
              },
              "canAfford": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "unlockedContent": {
      "type": "object",
      "description": "Buildings whose unlock tech you have already researched. This is a HISTORY of what you unlocked, not a list of what you may build — for that use buildableStructures.",
      "required": [
        "buildings"
      ],
      "properties": {
        "buildings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "trainableUnits": {
      "type": "object",
      "description": "The vocabulary for train_unit's \"unitType\": every unit your civilization can EVER train, nested building -> age -> ids, where the age is the earliest one at which that unit can be trained. Every leaf is a bare unit id, ready to pass as \"unitType\" unchanged. Includes your civ's unique units and omits any standard unit your civ does not field. A category (infantry/ranged/cavalry/support) is NOT valid here — those work only in the \"units\" parameter of move_units and attack_target.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "buildableStructures": {
      "type": "array",
      "description": "What your civilization can EVER build. If a type is absent (e.g. stable for some civs), your civ does not have it — do not keep trying.",
      "items": {
        "type": "object",
        "required": [
          "type",
          "requiresTech",
          "researched",
          "readyToBuild"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "requiresTech": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "researched": {
            "type": "boolean"
          },
          "readyToBuild": {
            "type": "boolean"
          }
        }
      }
    },
    "pendingBuildings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Building types queued but not yet placed."
    },
    "threats": {
      "type": "object",
      "description": "What demands an immediate response.",
      "required": [
        "underAttack",
        "enemyWonders"
      ],
      "properties": {
        "underAttack": {
          "type": "array",
          "description": "YOUR units/buildings that took damage in the last few seconds — defend now (attack the attackerAt position).",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "type",
              "x",
              "z",
              "healthPct",
              "attackerAt"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "building",
                  "unit"
                ]
              },
              "type": {
                "type": "string"
              },
              "x": {
                "type": "integer"
              },
              "z": {
                "type": "integer"
              },
              "healthPct": {
                "type": "integer"
              },
              "attackerAt": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": [
                      "x",
                      "z",
                      "owner"
                    ],
                    "properties": {
                      "x": {
                        "type": "integer"
                      },
                      "z": {
                        "type": "integer"
                      },
                      "owner": {
                        "type": "string"
                      }
                    }
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            }
          }
        },
        "enemyWonders": {
          "type": "array",
          "description": "Rival Wonders (always visible, even through fog). A complete one WINS for its owner in secondsUntilEnemyWins — existential threat.",
          "items": {
            "$ref": "#/properties/enemyBuildings/items"
          }
        }
      }
    },
    "gameStats": {
      "type": "object",
      "required": [
        "wonderTimer",
        "wonderRequired",
        "wonderHeld",
        "opponents"
      ],
      "properties": {
        "wonderTimer": {
          "type": "number"
        },
        "wonderRequired": {
          "type": "number",
          "description": "Seconds a finished Wonder must be held to win (600 by default)."
        },
        "wonderHeld": {
          "type": "boolean"
        },
        "opponents": {
          "type": "array",
          "description": "Every rival (rule-based ones and, in campaign, the human with id 'player'). civilization and age are ALWAYS present (epochs are public). units/buildings counts appear only once this player has DISCOVERED that rival (seen any of its units or buildings); until then discovered=false and the count fields are absent.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "civilization",
              "age",
              "discovered"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "civilization": {
                "type": "string"
              },
              "age": {
                "type": "string"
              },
              "discovered": {
                "type": "boolean"
              },
              "units": {
